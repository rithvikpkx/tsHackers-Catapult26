{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StudentCourseSnapshot",
  "type": "object",
  "required": [
    "code_module",
    "code_presentation",
    "highest_education",
    "age_band",
    "imd_band",
    "studied_credits",
    "num_of_prev_attempts",
    "disability"
  ],
  "properties": {
    "code_module": { "type": "string" },
    "code_presentation": { "type": "string" },
    "highest_education": { "type": "string" },
    "age_band": { "type": "string" },
    "imd_band": { "type": "string" },
    "studied_credits": { "type": "number", "minimum": 0 },
    "num_of_prev_attempts": { "type": "number", "minimum": 0 },
    "disability": { "type": "string" },
    "gender": { "type": "string" },
    "days_registered_before_start": { "type": "number", "minimum": 0 },
    "module_presentation_length": { "type": "number", "minimum": 0 },
    "unregistered_by_day_30": { "type": "number", "minimum": 0 },
    "day_of_unregistration_capped": { "type": "number", "minimum": 0 },
    "assessments_due_30d": { "type": "number", "minimum": 0 },
    "assessments_submitted_30d": { "type": "number", "minimum": 0 },
    "assessment_mean_score_30d": { "type": "number", "minimum": 0 },
    "weighted_score_pct_30d": { "type": "number", "minimum": 0 },
    "missing_submissions_30d": { "type": "number", "minimum": 0 },
    "late_submissions_30d": { "type": "number", "minimum": 0 },
    "total_clicks_30d": { "type": "number", "minimum": 0 },
    "active_days_30d": { "type": "number", "minimum": 0 },
    "unique_sites_30d": { "type": "number", "minimum": 0 },
    "unique_activity_types_30d": { "type": "number", "minimum": 0 },
    "pre_start_clicks": { "type": "number", "minimum": 0 },
    "post_start_clicks": { "type": "number", "minimum": 0 },
    "clicks_resource": { "type": "number", "minimum": 0 },
    "clicks_oucontent": { "type": "number", "minimum": 0 },
    "clicks_subpage": { "type": "number", "minimum": 0 },
    "clicks_url": { "type": "number", "minimum": 0 },
    "clicks_forumng": { "type": "number", "minimum": 0 },
    "clicks_quiz": { "type": "number", "minimum": 0 }
  },
  "additionalProperties": false
}
